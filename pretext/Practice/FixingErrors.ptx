  <exercise label="review3-fix-3">
     <statement>
        <p>
        What is wrong with this code snippet? How would you fix it?
        </p>
      </statement>
    <program xml:id="review3-fix-3" interactive="activecode" language="python">
      <input>
def print_numbers_to_n(n):
    for i in range(n):
        print(n)

print_numbers_to_n(5)
      </input>
    </program>
