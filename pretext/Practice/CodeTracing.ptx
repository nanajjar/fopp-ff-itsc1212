<section xml:id="practice-code-tracing">
  <title>Code Tracing</title>

  <p></p>
  <exercise label="review3-trace-1">
    <statement> Write the output of this code snippet. <pre>
count = 1
while count &lt;= 5:
    print(count)
    count += 1
    </pre>

    </statement>

    <response>
    </response>

  </exercise>

    <exercise label="review3-trace-2">
    <statement> Write the output of this code snippet. <pre>
for i in range(2, 10, 2):
    print(i)
    </pre>

    </statement>

    <response>
    </response>

  </exercise>
 <exercise label="review3-trace-3">
    <statement> Write the output of this code snippet. <pre>
x = 0
for i in range(3):
    x += i
print(x)
    </pre>

    </statement>

    <response>
    </response>

  </exercise>
  <exercise label="review3-trace-4">
    <statement> <p>Write the output of this code snippet.</p> <pre>
num = 5
while num > 0:
    if num % 2 == 0:
        print("even")
    else:
        print("odd")
    num -= 1
    </pre>

    </statement>

    <response>
    </response>

  </exercise>
