<?xml version="1.0"?>
<section xml:id="ch-lists">
    <title>Review - Lists</title>
    <introduction>
        <p>Practice indexing, updating, traversing, and using common list operations.</p>
    </introduction>
    <subsection>
        <title>Part A: Read the List</title>
        <exercise xml:id="ex-list-read">
            <statement>
                <program language="python">
colors = ["red", "blue", "green", "yellow"]</program>
                <p>Identify the first item, the last item, the item at index <c>2</c>, and the length of the list.</p>
            </statement>
 <response>
    </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part B: Trace</title>
        <exercise xml:id="ex-list-trace">
            <statement>
                <program language="python">
numbers = [10, 20, 30]
numbers.append(40)
numbers[1] = 99
numbers.pop(0)</program>
                <p>Trace the value of <c>numbers</c> after each line.</p>
            </statement>
 <response>
    </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part C: Fix</title>
        <exercise xml:id="ex-list-fix-1">
            <statement>
                <program language="python">
values = [1, 2, 3]
print(values[3])</program>
                <p>Correct the mistake.</p>
            </statement>
 <response>
    </response>
        </exercise>
        <exercise xml:id="ex-list-fix-2">
            <statement>
                <program language="python">
names = ["Ana", "Ben"]
names.replace("Ana", "Ali")</program>
                <p>Correct the mistake.</p>
            </statement>
 <response>
    </response>
        </exercise>
        <exercise xml:id="ex-list-fix-3">
            <statement>
                <program language="python">
scores = [80, 90, 100]
scores.append[70]</program>
                <p>Correct the mistake.</p>
            </statement>
 <response>
    </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part D: Create</title>
        <exercise xml:id="ex-list-create">
            <statement>
                <p>Write a list named <c>foods</c> containing four food names. Print the second item, add one more item, and replace the first item with a new value.</p>
            </statement>
 <response>
    </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Think About ...</title>
        <exercise xml:id="ex-list-reflection">
            <statement>
                <p>What is the difference between changing a list item and adding a new list item?</p>
            </statement>
 <response>
    </response>
        </exercise>
    </subsection>
</section>