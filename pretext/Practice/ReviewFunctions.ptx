<?xml version="1.0"?>
<section xml:id="ch-functions">
    <title>Review - Functions</title>
    <introduction>
        <p>Practice reading, tracing, testing, and writing simple functions.</p>
    </introduction>
    <subsection>
        <title>Part A: Recognize</title>
        <exercise xml:id="ex-fn-recognize">
            <statement>
                <p>Study the function below and label the function name, parameter, return statement, function call, and argument.</p>
                <program language="python">
def double(value):
    return value * 2

result = double(5)</program>
            </statement>
            <response>
            </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part B: Trace</title>
        <exercise xml:id="ex-fn-trace">
            <statement>
                <program language="python">
def add_one(num):
    return num + 1</program>
                <p>What value is returned by <c>add_one(4)</c>,                    <c>add_one(10)</c>, and <c>add_one(-1)</c>?
                </p>
            </statement>
            <response>
            </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part C: Match</title>
        <exercise xml:id="ex-fn-match">
            <statement>
                <p>Match each function to its purpose.</p>

            </statement>
            <cardsort>

                <match>
  <premise order="6"> <program language="python">
def a_function(x):
    return x ** x
                        </program></premise>
  </match>
                <match>
                    <premise order="3">
                        <program language="python">
def a_function(x):
    return x * x
                        </program>
                    </premise>
                     <premise order="4">
                        <program language="python">
def a_function(x):
    return x ** 2
                        </program>
                    </premise>
                    <response>returns the square of a number</response>
                </match>
                <match>
                    <premise order="5">
                        <program language="python">
def a_function(name):
    return "Hello, " + name
                        </program>
                    </premise>
                    <response>returns a greeting string</response>
                </match>
                <match>
                    <premise order="1">
                        <program language="python">
def a_function(num):
    return num > 0</program>
                    </premise>
                    <premise order="2">
                        <program language="python">
def a_function(num):
    return num >= 1</program>
                    </premise>
                    <response>checks whether a number is positive</response>
                </match>

            </cardsort>
        </exercise>
    </subsection>
    <subsection>
        <title>Part D: Fix</title>
        <exercise xml:id="ex-fn-fix">
            <statement>
                <p>Correct the errors in the function below.</p>
                <program xml:id="review_functions" interactive="activecode" language="python">
def multiply(a, b)
    result = a * b
    print return result</program>
            </statement>
            <response>
            </response>
        </exercise>
    </subsection>
    <subsection>
        <title>Part E: Create</title>
        <exercise xml:id="ex-fn-create">
            <statement>
                <p>Write a function named <c>subtract</c> that takes two parameters and returns the difference of the first minus the second. Then write three test calls.</p>
            </statement>
            <program xml:id="review_functions2" interactive="activecode" language="python">
            </program>
        </exercise>
    </subsection>
    <subsection>
        <title>Think About ...</title>
        <exercise xml:id="ex-fn-reflection">
            <statement>
                <p>What is the difference between <c>print()</c> and <c>return</c> inside a function?</p>
            </statement>
            <response>
            </response>
        </exercise>
    </subsection>
</section>